{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "rafaeloaguirre",
  "compatibility_date": "2026-04-03",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "env": {
    "staging": {
      "routes": [
        {
          "pattern": "staging.rafaeloaguirre.com",
          "custom_domain": true,
        },
      ],
    },
  },
}
