---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Rafael Aguirre.">
  <section class="py-16">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
      Contact
    </h1>
    <p class="mt-4 text-slate-600 dark:text-slate-400">
      The best way to reach me is by email. I also post on GitHub and LinkedIn.
    </p>

    <ul class="mt-10 space-y-4">
      {[
        { label: 'Email', value: 'hey@rafaeloaguirre.com', href: 'mailto:hey@rafaeloaguirre.com' },
        { label: 'GitHub', value: 'github.com/rafaeloaguirre', href: 'https://github.com/rafaeloaguirre' },
        { label: 'LinkedIn', value: 'linkedin.com/in/rafaeloaguirre', href: 'https://linkedin.com/in/rafaeloaguirre' },
      ].map(({ label, value, href }) => (
        <li class="flex items-center gap-4">
          <span class="w-20 shrink-0 text-sm font-medium text-slate-400 dark:text-slate-500">{label}</span>
          <a
            href={href}
            target={href.startsWith('http') ? '_blank' : undefined}
            rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="text-sm text-slate-700 hover:text-blue-600 dark:text-slate-300 dark:hover:text-blue-400 transition-colors"
          >
            {value}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
