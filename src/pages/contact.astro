---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Rafael Aguirre about full-stack development, technical direction, and focused consulting across SaaS, commerce, cloud, blockchain, and AI-enabled product systems."
>
  <section class="py-16">
    <p class="section-kicker">Contact</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">Contact</h1>
    <p class="mt-4 text-base leading-8 text-[var(--site-muted)]">
      Looking for a senior technical lead who can own technical direction, architecture, and
      delivery across product and platform systems? I also take on focused consulting work where
      teams need software architecture reviews, technical direction, AI-enabled workflow and tooling
      reviews, or hands-on delivery support.
    </p>

    <div class="panel-card mt-10 rounded-[1.8rem] p-7">
      <ul class="space-y-5">
        {
          [
            {
              label: 'Email',
              value: 'hey@rafaeloaguirre.com',
              href: 'mailto:hey@rafaeloaguirre.com',
            },
          ].map(({ label, value, href }) => (
            <li class="flex items-center gap-4">
              <span class="w-20 shrink-0 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--site-muted)]">
                {label}
              </span>
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="text-sm text-[var(--site-ink)] hover:text-[var(--site-accent)]"
              >
                {value}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
