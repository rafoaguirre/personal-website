---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Rafael Aguirre.">
  <section class="py-16">
    <p class="section-kicker">contact</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">Contact</h1>
    <p class="mt-4 text-base leading-8 text-[var(--site-muted)]">
      The best way to reach me is by email. I also post on LinkedIn.
    </p>

    <div class="panel-card mt-10 rounded-[1.8rem] p-7">
      <ul class="space-y-5">
        {
          [
            {
              label: 'Email',
              value: 'hey@rafaeloaguirre.com',
              href: 'mailto:hey@rafaeloaguirre.com',
            },
            {
              label: 'LinkedIn',
              value: 'linkedin.com/in/rafaeloaguirre',
              href: 'https://linkedin.com/in/rafaeloaguirre',
            },
          ].map(({ label, value, href }) => (
            <li class="flex items-center gap-4">
              <span class="w-20 shrink-0 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--site-muted)]">
                {label}
              </span>
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="text-sm text-[var(--site-ink)] hover:text-[var(--site-accent)]"
              >
                {value}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
