---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Articles"
  description="Technical writing by Rafael Aguirre on software engineering, architecture, and craft."
>
  <section class="py-16">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Articles</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      Writing on software engineering, architecture, and the craft of building good systems.
    </p>

    <div class="mt-10">
      {
        articles.length === 0 ? (
          <p class="text-slate-500 dark:text-slate-500">No articles yet. Check back soon.</p>
        ) : (
          articles.map((article) => (
            <ArticleCard
              id={article.id}
              title={article.data.title}
              description={article.data.description}
              publishedAt={article.data.publishedAt}
              tags={article.data.tags}
            />
          ))
        )
      }
    </div>
  </section>
</BaseLayout>
