---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Articles"
  description="Technical writing by Rafael Aguirre on software engineering, architecture, and craft."
>
  <section class="py-16">
    <p class="section-kicker">Articles</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">Articles</h1>
    <p class="mt-4 text-base leading-8 text-[var(--site-muted)]">
      Writing on software engineering, architecture, and the craft of building good systems.
    </p>

    <div class="mt-10 grid gap-5">
      {
        articles.length === 0 ? (
          <p class="panel-card rounded-[1.4rem] p-6 text-[var(--site-muted)]">
            No articles yet. Check back soon.
          </p>
        ) : (
          articles.map((article) => (
            <ArticleCard
              id={article.id}
              title={article.data.title}
              description={article.data.description}
              publishedAt={article.data.publishedAt}
              tags={article.data.tags}
            />
          ))
        )
      }
    </div>
  </section>
</BaseLayout>
