---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  {
    category: 'Blockchain',
    items: ['Solidity', 'Hardhat', 'ethers.js', 'Solana', 'Anchor', 'DApps', 'Wallets'],
  },
  { category: 'Languages', items: ['Rust', 'Golang', 'TypeScript', 'JavaScript', 'Dart'] },
  { category: 'Frontend / Mobile', items: ['React', 'Next.js', 'React Native', 'Flutter'] },
  { category: 'Cloud / DevOps', items: ['AWS', 'GCP', 'Terraform', 'CI/CD', 'SRE'] },
  { category: 'Data', items: ['PostgreSQL', 'MongoDB'] },
  { category: 'Tooling', items: ['GitHub Copilot', 'Codex', 'MCP servers', 'VS Code'] },
];
---

<BaseLayout
  title="About"
  description="Background, experience, and technical focus of Rafael Aguirre."
>
  <section class="py-16">
    <p class="section-kicker">About</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">About</h1>

    <div
      class="panel-card mt-8 rounded-[1.8rem] p-7 space-y-6 text-base leading-8 text-[var(--site-muted)]"
    >
      <p>
        I am a blockchain-focused software engineer with more than eight years of experience
        designing, building, deploying, and maintaining systems across Web3, backend, mobile, and
        cloud. My work usually sits at the intersection of architecture and delivery: turning
        complex technical requirements into software that can survive real usage.
      </p>
      <p>
        The strongest thread through my experience is blockchain architecture across EVM and Solana
        ecosystems, including smart contracts, DApps, wallet products, NFT systems, decentralized
        exchange interfaces, and event-driven trading workflows. Around that, I stay close to the
        infrastructure: CI/CD, SRE practices, cloud environments, automation, and reliability.
      </p>
      <p>
        I also care about technical writing as a way to sharpen judgment and make the reasoning
        behind engineering decisions more explicit. This site is where I document projects, share
        what I am learning, and show the kinds of systems work I enjoy doing most.
      </p>
    </div>

    <div class="mt-16 border-t border-[var(--site-line)] pt-12">
      <h2 class="mb-8 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
        Skills &amp; Tools
      </h2>
      <dl class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {
          skills.map(({ category, items }) => (
            <div class="panel-card rounded-[1.5rem] p-5">
              <dt class="text-lg font-semibold text-[var(--site-ink)]">{category}</dt>
              <dd class="mt-3 flex flex-wrap gap-2">
                {items.map((item) => (
                  <span class="inline-block rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1 text-xs font-mono text-[var(--site-muted)]">
                    {item}
                  </span>
                ))}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="mt-16 border-t border-[var(--site-line)] pt-12">
      <h2 class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
        Find me
      </h2>
      <ul class="flex flex-wrap gap-4">
        {
          [
            { label: 'GitHub', href: 'https://github.com/rafoaguirre' },
            { label: 'LinkedIn', href: 'https://linkedin.com/in/rafaeloaguirre' },
          ].map(({ label, href }) => (
            <li>
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="rounded-full border border-[var(--site-line)] bg-[var(--site-panel)] px-4 py-2 text-sm font-medium text-[var(--site-ink)] hover:border-[var(--site-accent)] hover:text-[var(--site-accent)]"
              >
                {label} →
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
