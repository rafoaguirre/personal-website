---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  { category: 'Frontend', items: ['React', 'Next.js', 'TypeScript', 'React Native', 'Flutter'] },
  { category: 'Backend', items: ['Node.js', 'Go', 'Rust', 'REST APIs'] },
  {
    category: 'Blockchain',
    items: ['Solidity', 'EVM', 'Solana', 'Smart contracts', 'Wallet integrations'],
  },
  { category: 'Cloud', items: ['AWS', 'GCP', 'Terraform'] },
  { category: 'Data', items: ['PostgreSQL', 'MongoDB'] },
  {
    category: 'AI & Delivery Tooling',
    items: ['GitHub Copilot', 'Codex', 'MCP servers', 'AI workflow tooling', 'CI/CD workflows'],
  },
];
---

<BaseLayout
  title="About"
  description="Technical lead and senior full-stack developer with product and platform systems experience across commerce, cloud, blockchain, and AI-enabled work."
>
  <section class="py-16">
    <p class="section-kicker">About</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">About</h1>

    <div
      class="panel-card mt-8 rounded-[1.8rem] p-7 space-y-6 text-base leading-8 text-[var(--site-muted)]"
    >
      <p>
        I am a technical lead and senior full-stack developer with 9+ years of experience building
        production systems across SaaS, commerce, cloud, and blockchain products.
      </p>
      <p>
        The through line in my work is technical ownership: shaping architecture, translating
        ambiguous requirements, and driving execution across backend services, frontends, payments,
        infrastructure, and operational workflows.
      </p>
      <p>
        Blockchain is a meaningful part of that background, especially in smart contract
        integrations, wallet products, payment platforms, and exchange-adjacent systems, but it sits
        inside a broader product and platform practice rather than replacing it.
      </p>
      <p>
        Beyond implementation, I contribute through design documentation, architecture reviews,
        technical proposals, development standards, mentoring, and delivery alignment. I use
        AI-assisted workflows where they improve speed without lowering technical quality, and I
        have built MCP-based tool orchestration, secure integration gateways, and workflow-driven AI
        features for tool-enabled products.
      </p>
    </div>

    <div class="mt-16 border-t border-[var(--site-line)] pt-12">
      <h2 class="mb-8 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
        Tech Stack
      </h2>
      <dl class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {
          skills.map(({ category, items }) => (
            <div class="panel-card rounded-[1.5rem] p-5">
              <dt class="text-lg font-semibold text-[var(--site-ink)]">{category}</dt>
              <dd class="mt-3 flex flex-wrap gap-2">
                {items.map((item) => (
                  <span class="inline-block rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1 text-xs font-mono text-[var(--site-muted)]">
                    {item}
                  </span>
                ))}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="mt-16 border-t border-[var(--site-line)] pt-12">
      <h2 class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
        Find me
      </h2>
      <ul class="flex flex-wrap gap-4">
        {
          [{ label: 'GitHub', href: 'https://github.com/rafoaguirre' }].map(({ label, href }) => (
            <li>
              <a
                href={href}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="rounded-full border border-[var(--site-line)] bg-[var(--site-panel)] px-4 py-2 text-sm font-medium text-[var(--site-ink)] hover:border-[var(--site-accent)] hover:text-[var(--site-accent)]"
              >
                {label} →
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
