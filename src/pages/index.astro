---
import { getCollection } from 'astro:content';
import { siGithub } from 'simple-icons';
import ArticleCard from '../components/ArticleCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TechMarquee from '../components/TechMarquee.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((project) => project.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const workStats = [
  { label: 'Years delivering production systems', value: '9+' },
  { label: 'Architecture-heavy client systems delivered', value: '10+' },
  { label: 'Team scale led', value: 'up to 15' },
  { label: 'Years across blockchain and product systems', value: '9+' },
];

const workNotes = [
  'platform architecture',
  'commerce and payment flows',
  'backend and cloud systems',
  'architecture reviews and design docs',
  'AI workflows and tool orchestration',
  'blockchain integrations where they fit',
];

type ContractorProject = {
  name: string;
  href: string;
  label: string;
  image?: string;
  fallbackTag?: string;
  fallbackSummary?: string;
};

const focusAreas = [
  {
    title: 'Platform architecture and delivery',
    detail:
      'System design, package boundaries, technical decision-making, and end-to-end execution for products that need to keep evolving after launch.',
  },
  {
    title: 'Commerce and payment systems',
    detail:
      'Checkout flows, payment integrations, order workflows, webhook handling, and the operational details that make commerce products reliable.',
  },
  {
    title: 'Backend, cloud, and AI systems',
    detail:
      'APIs, background jobs, queues, secure integration gateways, workflow execution, and infrastructure decisions that support real product constraints.',
  },
  {
    title: 'Blockchain integrations where they fit',
    detail:
      'Smart contract integrations, wallets, and exchange-adjacent product systems used where they support the product rather than dominate it.',
  },
];

const consultingAreas = [
  {
    title: 'Software architecture reviews',
    detail:
      'Independent review of system design, platform boundaries, technical risk, scalability, implementation tradeoffs, and delivery plans.',
  },
  {
    title: 'Prototype and product direction',
    detail:
      'Turning an early idea into a practical technical scope, first build path, milestone plan, and implementation slice.',
  },
  {
    title: 'AI-enabled workflow systems',
    detail:
      'Workflow audits, secure tool integrations, MCP/tool orchestration, internal automation, and implementation support around real business processes.',
  },
];

const workApproach = [
  'I translate unclear ideas into structured, working systems.',
  'I set technical standards and mentor teams through complex builds.',
  'I align clients, product, design, and development teams around scope and tradeoffs.',
  'I prioritize maintainability and long-term scalability.',
  'I move quickly without over-engineering.',
  'I use AI where it improves delivery, and I build secure tool and workflow infrastructure when products need it.',
];

const experience = [
  {
    role: 'Technical Lead / Senior Full-Stack Developer (Founder)',
    company: 'EastCode Blockchain Labs',
    period: '2017 - Present',
    location: 'Canada',
    points: [
      'Lead architecture and delivery across custom web, mobile, backend, blockchain, and cloud systems for client engagements.',
      'Built production platforms including payment systems, admin systems, wallet applications, NFT tooling, and decentralized exchange products.',
      'Set technical direction through proposals, architecture reviews, design documentation, development standards, and mentoring across teams of up to 15 people.',
      'Integrated smart contracts across EVM and Solana ecosystems while guiding delivery quality and cross-functional execution.',
    ],
  },
  {
    role: 'Infrastructure Developer',
    company: 'ATMTA Inc.',
    period: '2021 - 2023',
    location: 'Remote',
    points: [
      'Managed infrastructure supporting the Star Atlas marketplace and related blockchain platform services during a high-traffic production launch.',
      'Led deployment, environment, and secret-management decisions that improved release consistency and reduced operational risk.',
      'Assessed infrastructure requirements for new services, performed scalability testing, and guided follow-up optimization based on production needs.',
    ],
  },
  {
    role: 'Development Lead',
    company: 'Multichain Ventures',
    period: '2018 - 2020',
    location: 'Remote',
    points: [
      'Led development of React Native wallet features, including two-factor authentication and transaction-management workflows, with emphasis on release quality.',
      'Built reusable internal tooling and shared npm packages that standardized implementation patterns across the team.',
      'Owned DevOps, Kubernetes, SRE, and development workflow standards that improved delivery consistency across supported platforms.',
    ],
  },
  {
    role: 'Software Developer',
    company: 'Tokes Platform',
    period: '2017 - 2020',
    location: 'Remote',
    points: [
      'Built blockchain payment, explorer, and transaction-visibility systems around a blockchain-based payments platform.',
      'Implemented KYC and third-party integration workflows that extended platform capabilities and supported operational finance requirements.',
      'Contributed to platform integrations and operational tooling that improved visibility and extended product functionality.',
    ],
  },
  {
    role: 'Software Developer',
    company: 'Sigwo Technologies',
    period: '2017 - 2019',
    location: 'Remote',
    points: [
      'Worked on blockchain product concepts across custom chain integrations and distributed application tooling.',
      'Developed cross-chain and decentralized application concepts, including bridge and database tooling, for blockchain product use cases.',
      'Handled supporting infrastructure and prototype delivery for blockchain-oriented application work.',
    ],
  },
];

const caseStudies = [
  {
    title: 'Marketplace launch infrastructure',
    context: 'Blockchain marketplace / infrastructure-heavy launch',
    owned:
      'Owned launch-readiness planning, deployment workflows, secret management, and post-launch scalability work.',
    outcome:
      'Helped the platform move through a high-traffic release window with stronger operational consistency and a clearer path for follow-up optimization.',
  },
  {
    title: 'Exchange and blockchain product architecture',
    context: 'DEX, payments, NFT, and smart contract systems',
    owned:
      'Led architecture and technical direction across smart contract integrations, admin tooling, wallet flows, and client-facing product systems.',
    outcome:
      'Turned ambiguous product requirements into shippable systems while keeping integration quality, maintainability, and delivery standards intact.',
  },
];

const contractorProjects: ContractorProject[] = [
  {
    name: 'AI workflow platform',
    href: 'https://www.pentos.ai',
    label: 'Secure tool orchestration',
    image: '/project-previews/pentos-homepage-preview.png',
  },
  {
    name: 'Claynosaurz',
    href: 'https://collect.claynosaurz.com/',
    label: 'Collectibles / badges experience',
    image: '/project-previews/claynosaurz-homepage-preview.png',
  },
  {
    name: 'SpiritSwap',
    href: 'https://spiritswap.finance/',
    label: 'DeFi / DEX interface',
    image: '/project-previews/spiritswap-homepage-preview.png',
  },
  {
    name: 'Star Atlas',
    href: 'https://staratlas.com/',
    label: 'Blockchain game',
    image: '/project-previews/star-atlas-homepage-preview.png',
  },
  {
    name: 'Nymble',
    href: 'https://nymble.world/',
    label: 'Nostr social client',
    image: '/project-previews/nymble-homepage-preview.png',
  },
  {
    name: 'Tokes Platform',
    href: 'https://multichain.ventures/tokes.html',
    label: 'Blockchain payments',
    image: '/project-previews/tokes-homepage-preview.png',
  },
];

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rafael Aguirre',
  url: 'https://rafaeloaguirre.com',
  jobTitle: 'Senior Full-Stack Developer and Technical Lead',
  description:
    'Software architecture consultant and senior full-stack developer helping teams plan, review, and deliver product and platform systems.',
  sameAs: ['https://github.com/rafoaguirre'],
  knowsAbout: [
    'Software architecture',
    'Full-stack development',
    'Platform systems',
    'SaaS',
    'Commerce systems',
    'Cloud infrastructure',
    'Blockchain integrations',
    'AI-enabled workflow systems',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Focused consulting',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Software architecture reviews',
          description:
            'Architecture review, technical risk assessment, platform boundary review, and delivery planning.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Prototype and product direction',
          description:
            'Technical scoping and implementation planning for early product ideas and prototypes.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'AI-enabled workflow systems',
          description:
            'Workflow audits, secure tool integrations, AI workflow tooling, and implementation support.',
        },
      },
    ],
  },
};
---

<BaseLayout
  title="Software Architecture Consultant"
  description="Software architecture consultant and senior full-stack developer helping teams plan, review, and deliver product/platform systems, AI-enabled workflows, commerce, cloud, and blockchain integrations."
  jsonLd={homeJsonLd}
>
  <section class="grid gap-8 pb-10 pt-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-stretch lg:gap-10">
    <div class="panel-card relative overflow-hidden rounded-[2.2rem] p-8 sm:p-10 lg:p-12">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(232,95,59,0.18),transparent_28rem),radial-gradient(circle_at_90%_30%,rgba(20,117,122,0.15),transparent_22rem)]"
      >
      </div>
      <div class="comic-dots absolute inset-0 opacity-35"></div>
      <div class="relative">
        <p class="section-kicker">Architecture, Delivery, and Product &amp; Platform Systems</p>
        <p class="mt-6 text-sm font-medium uppercase tracking-[0.18em] text-[var(--site-muted)]">
          Rafael Aguirre
        </p>
        <h1
          class="mt-2 max-w-3xl text-3xl leading-tight font-semibold text-[var(--site-ink)] sm:text-4xl lg:text-5xl"
        >
          I design and ship product systems where architecture, execution, and operational reality
          all matter.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--site-muted)] sm:text-xl">
          I work with founders and product teams to turn ambiguous requirements into maintainable
          platforms across backend services, frontend applications, payments, cloud infrastructure,
          and delivery workflows.
        </p>
        <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--site-muted)]">
          Looking for someone to own technical direction and execution across product and platform
          systems? Let&apos;s talk.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="rounded-full border border-[var(--site-ink)] bg-[var(--site-ink)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-bg-soft)] hover:-translate-y-0.5 hover:bg-[var(--site-accent)]"
          >
            Let&apos;s talk
          </a>
          <a
            href="/projects"
            class="rounded-full border border-[var(--site-line)] bg-[var(--site-panel)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-ink)] hover:-translate-y-0.5 hover:border-[var(--site-accent)]"
          >
            See projects
          </a>
        </div>
      </div>
    </div>

    <div class="grid gap-4">
      <div class="panel-card site-grid relative overflow-hidden rounded-[2rem] p-6 sm:p-8">
        <div
          class="absolute -right-8 top-8 h-28 w-28 rounded-full border-2 border-[var(--site-ink)] bg-[var(--site-yellow)]"
        >
        </div>
        <div class="relative pt-10">
          <h2 class="max-w-md text-3xl font-semibold text-[var(--site-ink)] sm:text-4xl">
            What I Do
          </h2>
          <p class="mt-4 max-w-lg text-base leading-7 text-[var(--site-muted)]">
            I work across SaaS, commerce, cloud, blockchain, and AI-enabled products, with the most
            value in architecture-heavy builds that need clear boundaries, reliable execution, and
            room to evolve.
          </p>
          <div class="mt-8 flex flex-wrap gap-2">
            {
              workNotes.map((note) => (
                <span class="rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--site-muted)]">
                  {note}
                </span>
              ))
            }
          </div>
        </div>
      </div>
      <div class="panel-card rounded-[2rem] p-6">
        <p
          class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]"
        >
          How I Work
        </p>
        <ul class="mt-3 space-y-2 text-sm leading-7 text-[var(--site-muted)]">
          {workApproach.map((point) => <li>{point}</li>)}
        </ul>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {
            workStats.map((stat) => (
              <div class="rounded-[1.4rem] border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-4 py-4">
                <p class="text-2xl font-semibold text-[var(--site-ink)]">{stat.value}</p>
                <p class="mt-2 text-sm leading-6 text-[var(--site-muted)]">{stat.label}</p>
              </div>
            ))
          }
        </div>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <a
            href="https://github.com/rafoaguirre"
            target="_blank"
            rel="noopener noreferrer"
            class="flex min-h-24 items-center gap-4 rounded-[1.4rem] border border-[var(--site-line)] bg-[var(--site-panel)] p-4 hover:-translate-y-0.5"
            aria-label="GitHub"
          >
            <span
              class="flex h-14 w-14 items-center justify-center rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] text-[var(--site-ink)]"
            >
              <svg viewBox="0 0 24 24" class="h-7 w-7 fill-current" aria-hidden="true">
                <path d={siGithub.path}></path>
              </svg>
            </span>
            <span class="min-w-0">
              <span class="block text-sm font-semibold text-[var(--site-ink)]">GitHub</span>
              <span class="block text-xs text-[var(--site-muted)]">Code and public work</span>
            </span>
          </a>
          <a
            href="/contact"
            class="flex min-h-24 items-center gap-4 rounded-[1.4rem] border border-[var(--site-line)] bg-[var(--site-panel)] p-4 hover:-translate-y-0.5"
            aria-label="Contact"
          >
            <span
              class="flex h-14 w-14 items-center justify-center rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] text-[var(--site-accent)]"
            >
              <span class="text-lg font-semibold">@</span>
            </span>
            <span class="min-w-0">
              <span class="block text-sm font-semibold text-[var(--site-ink)]">Contact</span>
              <span class="block text-xs text-[var(--site-muted)]">Email for project inquiries</span
              >
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <TechMarquee />
  </section>

  <section id="about" class="border-t border-[var(--site-line)] py-20">
    <div class="mb-8 max-w-4xl">
      <p class="section-kicker">Where I Add Leverage</p>
      <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
        I&apos;m most useful where architecture, execution, and product ambiguity overlap.
      </h2>
    </div>
    <div class="panel-card rounded-[1.7rem] p-6 sm:p-7">
      <p class="text-base leading-8 text-[var(--site-muted)]">
        I work across SaaS, commerce, cloud, blockchain, and AI-enabled products, with the most
        value in architecture-heavy builds that need clear boundaries, reliable execution, and room
        to evolve.
      </p>
      <p class="mt-4 text-base leading-8 text-[var(--site-muted)]">
        The through line is technical ownership: shaping architecture, writing design documentation,
        aligning stakeholders around tradeoffs, mentoring developers, and keeping systems adaptable
        as requirements evolve.
      </p>
    </div>
    <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        focusAreas.map((area) => (
          <article class="panel-card rounded-[1.5rem] p-5">
            <h3 class="text-xl font-semibold text-[var(--site-ink)]">{area.title}</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--site-muted)]">{area.detail}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="consulting" class="border-t border-[var(--site-line)] py-20">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-4xl">
        <p class="section-kicker">Focused Consulting</p>
        <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
          Senior technical judgment for architecture, prototypes, and AI-enabled workflow systems.
        </h2>
      </div>
      <p class="max-w-xl text-sm leading-7 text-[var(--site-muted)]">
        Short, focused engagements for teams that need practical direction before or during a build,
        without turning the work into a long agency process.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        consultingAreas.map((area) => (
          <article class="panel-card rounded-[1.5rem] p-5">
            <h3 class="text-xl font-semibold text-[var(--site-ink)]">{area.title}</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--site-muted)]">{area.detail}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="max-w-2xl text-sm leading-7 text-[var(--site-muted)]">
        Best fit: architecture reviews, prototype planning, technical risk reviews, workflow audits,
        secure tool integrations, and hands-on implementation support.
      </p>
      <a
        href="/contact"
        class="w-fit rounded-full border border-[var(--site-ink)] bg-[var(--site-ink)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-bg-soft)] hover:-translate-y-0.5 hover:bg-[var(--site-accent)]"
      >
        Email about consulting
      </a>
    </div>
  </section>

  <section id="experience" class="border-t border-[var(--site-line)] py-20">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-kicker">Experience</p>
        <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
          Built through startups, client delivery, and infrastructure-heavy teams.
        </h2>
      </div>
      <p class="max-w-xl text-sm leading-7 text-[var(--site-muted)]">
        I focus on technical ownership, architecture decisions, and execution quality from planning
        through production support.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {
        experience.map((item) => (
          <article class="panel-card rounded-[1.7rem] p-6">
            <div class="flex flex-col gap-3 sm:min-h-[5.5rem] sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
                  {item.company}
                </p>
                <h3 class="mt-2 text-2xl font-semibold text-[var(--site-ink)]">{item.role}</h3>
              </div>
              <div class="min-w-[9.5rem] shrink-0 rounded-2xl border border-[var(--site-line)] px-4 py-2 text-center text-sm text-[var(--site-muted)]">
                <p>{item.period}</p>
                <p>{item.location}</p>
              </div>
            </div>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-[var(--site-muted)]">
              {item.points.map((point) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-[var(--site-accent)]" />
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section id="representative-work" class="border-t border-[var(--site-line)] py-20">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-kicker">Representative Engagements</p>
        <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
          A few examples of the kind of work I tend to own.
        </h2>
      </div>
      <p class="max-w-xl text-sm leading-7 text-[var(--site-muted)]">
        These are intentionally generalized, but they reflect the level of technical ownership,
        delivery responsibility, and production context I typically work in.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {
        caseStudies.map((study) => (
          <article class="panel-card rounded-[1.7rem] p-6">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
              {study.context}
            </p>
            <h3 class="mt-3 text-2xl font-semibold text-[var(--site-ink)]">{study.title}</h3>
            <div class="mt-5 space-y-4 text-sm leading-7 text-[var(--site-muted)]">
              <p>
                <span class="font-semibold text-[var(--site-ink)]">What I owned:</span>{' '}
                {study.owned}
              </p>
              <p>
                <span class="font-semibold text-[var(--site-ink)]">What changed:</span>{' '}
                {study.outcome}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section id="contract-work" class="border-t border-[var(--site-line)] py-20">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-kicker">Selected Work</p>
        <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
          Products and platforms where that work shows up publicly.
        </h2>
      </div>
      <p class="max-w-xl text-sm leading-7 text-[var(--site-muted)]">
        Public-facing examples across product and platform systems, tool-enabled workflows, gaming,
        and blockchain product environments.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-5">
      {
        contractorProjects.map((project) => (
          <a
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
            class="panel-card group w-full max-w-[24rem] overflow-hidden rounded-[1.7rem] hover:-translate-y-1"
          >
            {project.image ? (
              <div class="aspect-[16/10] overflow-hidden border-b border-[var(--site-line)] bg-[var(--site-bg-soft)]">
                <img
                  src={project.image}
                  alt={`${project.name} site preview`}
                  loading="lazy"
                  class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
                />
              </div>
            ) : (
              <div class="relative flex aspect-[16/10] items-end overflow-hidden border-b border-[var(--site-line)] bg-[linear-gradient(135deg,#0f1117,#1a2030_48%,#11424a)] p-6">
                <div class="absolute left-5 top-5 rounded-full border border-white/14 bg-white/8 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-white/70">
                  live product
                </div>
                <div class="absolute -right-8 top-8 h-28 w-28 rounded-full border border-white/10 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.28),rgba(255,255,255,0.02))]" />
                <div class="relative">
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-white/60">
                    {project.fallbackTag ?? project.name}
                  </p>
                  <p class="mt-2 max-w-[14rem] text-2xl font-semibold leading-tight text-white">
                    {project.fallbackSummary ?? project.label}
                  </p>
                </div>
              </div>
            )}
            <div class="p-6">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]">
                {project.label}
              </p>
              <h3 class="mt-3 text-2xl font-semibold text-[var(--site-ink)] group-hover:text-[var(--site-accent)]">
                {project.name}
              </h3>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {
    projects.length > 0 && (
      <section id="portfolio" class="border-t border-[var(--site-line)] py-20">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div>
            <p class="section-kicker">Portfolio</p>
            <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
              Projects I&apos;m building in public.
            </h2>
          </div>
          <a
            href="/projects"
            class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)] hover:text-[var(--site-accent)]"
          >
            All projects
          </a>
        </div>

        <div class="grid gap-5 lg:grid-cols-3">
          {projects.map((project) => (
            <ProjectCard
              id={project.id}
              title={project.data.title}
              summary={project.data.summary}
              stack={project.data.stack}
              year={project.data.year}
              repoUrl={project.data.repoUrl}
              liveUrl={project.data.liveUrl}
            />
          ))}
        </div>
      </section>
    )
  }

  {
    articles.length > 0 && (
      <section id="articles" class="border-t border-[var(--site-line)] py-20">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div>
            <p class="section-kicker">Articles</p>
            <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
              Writing about architecture, trade-offs, and what holds up in practice.
            </h2>
          </div>
          <a
            href="/articles"
            class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)] hover:text-[var(--site-accent)]"
          >
            All articles
          </a>
        </div>

        <div class="grid gap-5">
          {articles.map((article) => (
            <ArticleCard
              id={article.id}
              title={article.data.title}
              description={article.data.description}
              publishedAt={article.data.publishedAt}
              tags={article.data.tags}
            />
          ))}
        </div>
      </section>
    )
  }

  <section class="border-t border-[var(--site-line)] py-20">
    <div
      class="panel-card grid gap-6 rounded-[2rem] p-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:p-10"
    >
      <div>
        <p class="section-kicker">Working With Me</p>
        <h2 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">
          Looking for a senior technical lead who can own technical direction and execution?
        </h2>
      </div>
      <div class="space-y-4">
        <p class="text-base leading-7 text-[var(--site-muted)]">
          I work with founders and product teams to build new products, improve existing platforms,
          and deliver against real constraints across backend services, frontend applications,
          payments, infrastructure, and blockchain integrations where they fit.
        </p>
        <p class="text-base leading-7 text-[var(--site-muted)]">
          I also take on focused consulting work where teams need software architecture reviews,
          technical direction, AI-enabled workflow and tooling reviews, or hands-on delivery
          support.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/contact"
            class="rounded-full border border-[var(--site-ink)] bg-[var(--site-ink)] px-6 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--site-bg-soft)] hover:-translate-y-0.5 hover:bg-[var(--site-accent)]"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
