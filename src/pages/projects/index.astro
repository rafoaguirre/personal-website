---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Projects" description="Software projects and case studies by Rafael Aguirre.">
  <section class="py-16">
    <p class="section-kicker">projects</p>
    <h1 class="mt-5 text-4xl font-semibold text-[var(--site-ink)]">Projects</h1>
    <p class="mt-4 text-base leading-8 text-[var(--site-muted)]">
      A selection of things I've built, with context on the problem, approach, and outcome.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        projects.length === 0 ? (
          <p class="panel-card col-span-2 rounded-[1.4rem] p-6 text-[var(--site-muted)]">
            No projects listed yet. Check back soon.
          </p>
        ) : (
          projects.map((project) => (
            <ProjectCard
              id={project.id}
              title={project.data.title}
              summary={project.data.summary}
              stack={project.data.stack}
              year={project.data.year}
              repoUrl={project.data.repoUrl}
              liveUrl={project.data.liveUrl}
            />
          ))
        )
      }
    </div>
  </section>
</BaseLayout>
