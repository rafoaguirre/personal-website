---
import BaseLayout from './BaseLayout.astro';
import MermaidRenderer from '../components/MermaidRenderer.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
}

const { title, description, publishedAt, updatedAt, tags = [] } = Astro.props;

const formattedPublished = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const formattedUpdated = updatedAt?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout title={title} description={description}>
  <article class="py-16">
    <header class="mb-12 border-b border-[var(--site-line)] pb-8">
      <div class="mb-4 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="inline-block rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1 text-xs font-medium uppercase tracking-[0.12em] text-[var(--site-muted)]">
              {tag}
            </span>
          ))
        }
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-[var(--site-ink)] sm:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-[var(--site-muted)]">{description}</p>
      <div
        class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--site-muted)]"
      >
        <time datetime={publishedAt.toISOString()}>
          Published {formattedPublished}
        </time>
        {
          formattedUpdated && (
            <>
              <span>·</span>
              <time datetime={updatedAt!.toISOString()}>Updated {formattedUpdated}</time>
            </>
          )
        }
      </div>
    </header>

    <div
      class="prose max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-code:font-mono site-prose"
    >
      <slot />
    </div>
    <MermaidRenderer />

    <footer class="mt-16 border-t border-[var(--site-line)] pt-8">
      <a
        href="/articles"
        class="text-sm font-medium text-[var(--site-muted)] hover:text-[var(--site-accent)]"
      >
        ← All articles
      </a>
    </footer>
  </article>
</BaseLayout>
