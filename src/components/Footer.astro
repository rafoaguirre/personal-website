---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/rafoaguirre', label: 'GitHub' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<footer
  class="mb-12 mt-24 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 dark:border-slate-800 sm:flex-row"
>
  <div
    class="panel-card flex w-full flex-col gap-4 rounded-[1.6rem] px-6 py-6 sm:flex-row sm:items-center sm:justify-between"
  >
    <div>
      <p class="text-sm font-semibold text-[var(--site-ink)]">Rafael Aguirre</p>
      <p class="text-sm text-[var(--site-muted)]">
        Technical leadership for cloud, Web3, and product systems.
      </p>
    </div>
    <nav>
      <ul class="flex items-center gap-4 sm:gap-6">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm font-medium text-[var(--site-muted)] hover:text-[var(--site-accent)]"
                {...(href.startsWith('http')
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--site-muted)]">
      © {year}
    </p>
  </div>
</footer>
