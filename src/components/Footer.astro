---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/rafoaguirre', label: 'GitHub' },
  { href: 'https://linkedin.com/in/rafaeloaguirre', label: 'LinkedIn' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<footer class="mb-12 mt-24 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 dark:border-slate-800 sm:flex-row">
  <p class="text-sm text-slate-500 dark:text-slate-500">
    © {year} Rafael Aguirre
  </p>
  <nav>
    <ul class="flex items-center gap-6">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm text-slate-500 hover:text-slate-900 dark:text-slate-500 dark:hover:text-slate-100 transition-colors"
            {...(href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</footer>
