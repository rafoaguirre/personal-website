---
interface Props {
  id: string;
  title: string;
  summary: string;
  stack?: string[];
  year: number;
  repoUrl?: string;
  liveUrl?: string;
}

const { id, title, summary, stack = [], year, repoUrl, liveUrl } = Astro.props;
const slug = id.replace(/\.(md|mdx)$/, '');
---

<article
  class="panel-card group flex h-full flex-col rounded-[1.5rem] p-6 transition-transform hover:-translate-y-1"
>
  <div class="flex flex-1 items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <a href={`/projects/${slug}`} class="block">
        <!-- <p class="mb-3 text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[var(--site-muted)]">
          Portfolio note
        </p> -->
        <h2
          class="text-xl font-semibold text-[var(--site-ink)] group-hover:text-[var(--site-accent)]"
        >
          {title}
        </h2>
        <p class="mt-3 text-sm leading-6 text-[var(--site-muted)] line-clamp-3">
          {summary}
        </p>
      </a>
      {
        stack.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {stack.map((tech) => (
              <span class="inline-block rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1 text-xs font-mono text-[var(--site-muted)]">
                {tech}
              </span>
            ))}
          </div>
        )
      }
    </div>
    <span
      class="shrink-0 rounded-full border border-[var(--site-line)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)]"
    >
      {year}
    </span>
  </div>
  {
    (repoUrl || liveUrl) && (
      <div class="mt-5 flex gap-4 border-t border-[var(--site-line)] pt-4">
        {liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-medium uppercase tracking-[0.16em] text-[var(--site-muted)] hover:text-[var(--site-accent)]"
          >
            Live site →
          </a>
        )}
        {repoUrl && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-medium uppercase tracking-[0.16em] text-[var(--site-muted)] hover:text-[var(--site-accent)]"
          >
            GitHub →
          </a>
        )}
      </div>
    )
  }
</article>
