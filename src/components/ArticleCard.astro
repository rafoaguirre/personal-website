---
interface Props {
  id: string;
  title: string;
  description: string;
  publishedAt: Date;
  tags?: string[];
}

const { id, title, description, publishedAt, tags = [] } = Astro.props;

const slug = id.replace(/\.(md|mdx)$/, '');
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/articles/${slug}`} class="block py-6 border-b border-slate-100 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-600 transition-colors">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex-1 min-w-0">
        <h2 class="text-base font-semibold text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
          {title}
        </h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
          {description}
        </p>
        {tags.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1.5">
            {tags.map((tag) => (
              <span class="inline-block rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
      <time
        datetime={publishedAt.toISOString()}
        class="shrink-0 text-sm text-slate-400 dark:text-slate-500 sm:ml-6"
      >
        {formattedDate}
      </time>
    </div>
  </a>
</article>
