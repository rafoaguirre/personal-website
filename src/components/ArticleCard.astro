---
interface Props {
  id: string;
  title: string;
  description: string;
  publishedAt: Date;
  tags?: string[];
}

const { id, title, description, publishedAt, tags = [] } = Astro.props;

const slug = id.replace(/\.(md|mdx)$/, '');
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<article class="group">
  <a href={`/articles/${slug}`} class="panel-card block rounded-[1.4rem] p-6 hover:-translate-y-1">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="flex-1 min-w-0">
        <p
          class="mb-2 text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[var(--site-muted)]"
        >
          Article
        </p>
        <h2
          class="text-lg font-semibold text-[var(--site-ink)] group-hover:text-[var(--site-accent)]"
        >
          {title}
        </h2>
        <p class="mt-2 text-sm leading-6 text-[var(--site-muted)] line-clamp-2">
          {description}
        </p>
        {
          tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="inline-block rounded-full border border-[var(--site-line)] bg-[var(--site-panel-strong)] px-3 py-1 text-xs text-[var(--site-muted)]">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      <time
        datetime={publishedAt.toISOString()}
        class="shrink-0 rounded-full border border-[var(--site-line)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--site-muted)] sm:ml-6"
      >
        {formattedDate}
      </time>
    </div>
  </a>
</article>
